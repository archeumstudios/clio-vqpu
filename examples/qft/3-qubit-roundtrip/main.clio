.program qft_roundtrip_101
.shots 64
.trace off
QALLOC q0
QALLOC q1
QALLOC q2
QX q0
QX q2
QH q0
QCPHASE q1, q0, 1.5707963267948966
QCPHASE q2, q0, 0.7853981633974483
QH q1
QCPHASE q2, q1, 1.5707963267948966
QH q2
QSWAP q0, q2
QSWAP q0, q2
QH q2
QCPHASE q2, q1, -1.5707963267948966
QH q1
QCPHASE q2, q0, -0.7853981633974483
QCPHASE q1, q0, -1.5707963267948966
QH q0
QMEASURE q0, m0
QMEASURE q1, m1
QMEASURE q2, m2
HALT
